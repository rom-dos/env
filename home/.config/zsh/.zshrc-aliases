# Report function for timewarrior using export and jq
rp() {
  local tag="$1"
  local period="$2"
  local range=""
  
  # Set the date range based on period
  case "$period" in
    "today")
      range="today"
      ;;
    "yesterday")
      range="yesterday"
      ;;
    "week")
      range="week"
      ;;
    "lastweek")
      range="sow - 1w to eow - 1w"
      ;;
    "month")
      range="month"
      ;;
    "lastmonth")
      range="som - 1m to eom - 1m"
      ;;
    "year")
      range="year"
      ;;
    "lastyear")
      range="soy - 1y to eoy - 1y"
      ;;
    *)
      echo "Usage: rp <tag> <period>"
      echo "Periods: today, yesterday, week, lastweek, month, lastmonth, year, lastyear"
      return 1
      ;;
  esac
  
  # Get timewarrior export data and filter with jq
  local output=$(timew export "$range" 2>/dev/null | jq -r --arg tag "$tag" '
    .[] |
    select(.tags != null) |
    select(any(.tags[]; ascii_downcase | contains($tag | ascii_downcase))) |
    select(.end != null) |
    ((.end | strptime("%Y%m%dT%H%M%SZ") | mktime) - (.start | strptime("%Y%m%dT%H%M%SZ") | mktime))
  ')
  
  if [[ -n "$output" && "$output" != "" ]]; then
    # Sum all the durations (in seconds) and convert to hours
    local total_seconds=$(echo "$output" | tr '\n' '+' | sed 's/+$//' | bc -l 2>/dev/null || echo "0")
    local total_hours=$(echo "scale=2; $total_seconds / 3600" | bc -l 2>/dev/null || echo "0.00")
    echo "Total hours for '$tag' ($period): $total_hours"
  else
    echo "No time tracked for '$tag' in period '$period'"
  fi
}
